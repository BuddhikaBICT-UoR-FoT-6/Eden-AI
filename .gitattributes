# Ensure consistent line endings across platforms
* text=auto

# Force Unix line endings for shell scripts and Java/Python sources
*.java   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.conf   text eol=lf
*.properties text eol=lf

# Binary files — no line ending conversion
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.jar    binary
*.zip    binary
